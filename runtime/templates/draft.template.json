{
  "job_id": "video-director-draft",
  "inputs": {
    "topic_hint": "local short video draft",
    "narration_text": "Open with the strongest local material, then move through process, context, and key details so the editable draft has a clear story structure. Close with a result shot or emotional moment.",
    "director_brief": "Prepare an editable draft handoff from local materials when the selected adapter and environment support it."
  },
  "production": {
    "full_tts_audio_path": "",
    "full_tts_duration_ms": 12000,
    "understanding": {
      "narrative_groups": [
        {
          "title": "opening context",
          "ocr_keywords": ["opening", "context", "theme"]
        },
        {
          "title": "process detail",
          "ocr_keywords": ["process", "detail", "action"]
        },
        {
          "title": "result close",
          "ocr_keywords": ["result", "ending", "summary"]
        }
      ]
    },
    "materials": [
      {
        "asset_id": "mat-01",
        "path": "input/materials/opening.mp4",
        "tags": ["opening", "context", "theme"]
      },
      {
        "asset_id": "mat-02",
        "path": "input/materials/process.mp4",
        "tags": ["process", "detail", "action"]
      },
      {
        "asset_id": "mat-03",
        "path": "input/materials/result.mp4",
        "tags": ["result", "ending", "summary"]
      }
    ]
  },
  "editing": {
    "resolution": "1080x1920",
    "fps": 30,
    "color_space": "rec709",
    "min_segment_ms": 2500,
    "chars_per_second": 8.0,
    "enable_avatar_timeline": false,
    "avatar_opening_segments": 0,
    "avatar_middle_segments": 0,
    "avatar_ending_segments": 0,
    "avatar_min_segments_for_middle": 5,
    "max_material_reuse": 2
  },
  "outputs": {
    "output_root": "output/video_director",
    "run_management": {
      "enabled": true,
      "runs_dirname": "runs",
      "latest_pointer_name": "latest_run.json"
    },
    "targets": ["jianying_draft"],
    "preview_enabled": false,
    "final_render_enabled": false,
    "jianying": {
      "use_pyjianyingdraft": true,
      "drafts_root": "output/video_director_jianying_drafts",
      "materialize_local_assets": true,
      "download_remote_assets": true,
      "draft_name": "video-director-draft",
      "subtitles": {
        "enabled": true,
        "font_size": 6.0,
        "font_color": "#FFFFFF",
        "bold": true,
        "align": 1,
        "auto_wrapping": true,
        "max_line_width": 0.84,
        "transform_y": -0.78,
        "border_enabled": true,
        "border_color": "#000000",
        "border_width": 42.0
      }
    }
  }
}
