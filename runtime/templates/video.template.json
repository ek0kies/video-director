{
  "job_id": "video-director-video",
  "inputs": {
    "topic_hint": "local short video",
    "narration_text": "Open with the strongest local material, then move through process, context, and key details so viewers quickly understand the story. Close with a result shot or emotional moment.",
    "director_brief": "Use local B-roll as the primary visual track and render a directly playable vertical mp4."
  },
  "production": {
    "enable_tts_generation": false,
    "tts": {
      "provider": "doubao_tts2_v3_http_chunked",
      "_note": "豆包普通语音合成默认使用 seed-tts-2.0，默认音色为 zh_male_jieshuoxiaoming_uranus_bigtts；seed-icl-2.0 是声音复刻，不用于普通 TTS。",
      "endpoint": "https://openspeech.bytedance.com/api/v3/tts/unidirectional",
      "api_key": "",
      "resource_id": "seed-tts-2.0",
      "output_file_name": "tts.wav",
      "speaker_id": "zh_male_jieshuoxiaoming_uranus_bigtts",
      "payload_template": {
        "request_id": "{{request_id}}",
        "req_params": {
          "speaker": "{{speaker_id}}",
          "text": "{{script_text}}",
          "audio_params": {
            "format": "wav"
          }
        }
      }
    },
    "full_tts_audio_path": "",
    "full_tts_duration_ms": 12000,
    "understanding": {
      "narrative_groups": [
        {
          "title": "opening context",
          "ocr_keywords": ["opening", "context", "theme"]
        },
        {
          "title": "process detail",
          "ocr_keywords": ["process", "detail", "action"]
        },
        {
          "title": "result close",
          "ocr_keywords": ["result", "ending", "summary"]
        }
      ]
    },
    "materials": [
      {
        "asset_id": "mat-01",
        "path": "input/materials/opening.mp4",
        "tags": ["opening", "context", "theme"]
      },
      {
        "asset_id": "mat-02",
        "path": "input/materials/process.mp4",
        "tags": ["process", "detail", "action"]
      },
      {
        "asset_id": "mat-03",
        "path": "input/materials/result.mp4",
        "tags": ["result", "ending", "summary"]
      }
    ]
  },
  "editing": {
    "resolution": "1080x1920",
    "fps": 30,
    "color_space": "rec709",
    "min_segment_ms": 2500,
    "chars_per_second": 8.0,
    "enable_avatar_timeline": false,
    "avatar_opening_segments": 0,
    "avatar_middle_segments": 0,
    "avatar_ending_segments": 0,
    "avatar_min_segments_for_middle": 5,
    "max_material_reuse": 2,
    "material_duration_policy": "cap",
    "final_tail_frames": 2,
    "final_tail_buffer_ms": 0,
    "final_fade_out_ms": 0
  },
  "outputs": {
    "output_root": "output/video_director",
    "run_management": {
      "enabled": true,
      "runs_dirname": "runs",
      "latest_pointer_name": "latest_run.json"
    },
    "targets": ["final_render"],
    "preview_enabled": false,
    "final_render_enabled": false,
    "final_render": {
      "output_name": "video-director-final.mp4",
      "burn_subtitles": true,
      "emit_sidecar_srt": false,
      "allow_sidecar_srt": false,
      "subtitle_strip_trailing_punctuation": true
    }
  }
}
